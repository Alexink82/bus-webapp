BACKEND_URL=http://localhost:8000

# WebPay callback: секрет для проверки callback (прод)
WEBPAY_CALLBACK_SECRET=

# CORS: для TG WebApp (cross-origin с t.me) по умолчанию origins=* и credentials=false.
# В проде можно ограничить: ALLOWED_ORIGINS=https://ваш-сервис.onrender.com (несколько через запятую)
# ALLOWED_ORIGINS=
# MAINTENANCE_UNTIL=2026-03-20T12:00:00Z
