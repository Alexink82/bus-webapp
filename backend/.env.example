# Копируй в .env и заполни значения.
# Локально: нужен PostgreSQL (см. README — Docker или установленный сервер).

# Telegram (опционально для локального запуска)
BOT_TOKEN=
CHANNEL_ID=
# Максимальный возраст Telegram initData в секундах (по умолчанию 24 часа)
# TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# Access (Telegram user IDs через запятую)
ADMIN_IDS=
DISPATCHER_IDS=

# Database — обязателен. Локально: PostgreSQL на порту 5432.
# Пример с Docker: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=bus_booking postgres:15
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bus_booking

# API keys
OPENWEATHER_API_KEY=

# App
DEBUG=true
WEBAPP_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# CORS (не задано — разрешены все origins, в т.ч. Telegram Web App)
# ALLOWED_ORIGINS=https://ваш-сервис.onrender.com,https://web.telegram.org

# Rate limit: запросов в минуту на IP (0 = выключено). По умолчанию 120.
# RATE_LIMIT=120

# Redis (опционально). Если задан — rate limit общий для всех воркеров.
# Upstash: rediss://default:ВАШ_ТОКЕН@хост.upstash.io:6379 (токен из Upstash Console)
# REDIS_URL=

# Sentry (опционально). DSN из Sentry → Project → Getting started.
# SENTRY_DSN=
# SENTRY_SEND_PII=0

# WebPay (прод)
WEBPAY_CALLBACK_SECRET=

# Privacy / retention
# Через сколько дней можно очищать сохранённые паспортные данные из saved_passengers
# SAVED_PASSENGER_PASSPORT_RETENTION_DAYS=365

# Browser/PWA backoffice auth (admin + dispatcher outside Telegram)
# Одноразовый ticket Telegram -> browser, секунды
# BROWSER_LOGIN_TICKET_TTL_SECONDS=60
# Длительность browser-session, часы
# BROWSER_SESSION_TTL_HOURS=12
# Как часто продлевать активную session, минуты
# BROWSER_SESSION_IDLE_REFRESH_MINUTES=5
# Имя cookie browser-session
# BROWSER_SESSION_COOKIE_NAME=bus_backoffice_session
